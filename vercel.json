{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "nextjs"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "crons": [
    {
      "path": "/api/cron/run-agents",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/observe-outcomes",
      "schedule": "0 14 * * *"
    }
  ]
}
